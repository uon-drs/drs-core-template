# ============================================================
# NextAuth
# ============================================================
# URL of this application (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Secret used to sign/encrypt NextAuth JWTs and cookies.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=<generate-with-openssl-rand-base64-32>

# ============================================================
# Keycloak
# ============================================================
# The client ID of the Keycloak public client created for this frontend
KEYCLOAK_CLIENT_ID=templateapp-frontend

# The client secret (leave empty for public/PKCE-only clients)
KEYCLOAK_CLIENT_SECRET=<from-keycloak-client-settings>

# Full issuer URL: https://<host>/realms/<realm>
KEYCLOAK_ISSUER=https://keycloak.example.com/realms/templateapp

# ============================================================
# Backend API
# ============================================================
# Base URL of the backend API (used in server components to call the API)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
